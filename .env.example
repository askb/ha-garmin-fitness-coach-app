# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your PostgreSQL database.
# For local dev: postgresql://dev:dev@localhost:5432/pulsecoach
POSTGRES_URL="postgresql://dev:dev@localhost:5432/pulsecoach"

# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='replace-with-output-of-openssl-rand-base64-32'

# Preconfigured Discord OAuth provider, works out-of-the-box
# @see https://www.better-auth.com/docs/authentication/discord
AUTH_DISCORD_ID=''
AUTH_DISCORD_SECRET=''

# Enable email/password sign-in for the standalone consumer deployment
# (Path B). Off by default; set to 'true' only on the consumer deployment.
# Leave empty/unset for social-only or the HA addon.
AUTH_ENABLE_EMAIL_PASSWORD=''

# Garmin Health API (apply at https://www.garmin.com/en-US/forms/GarminConnectDeveloperAccess/)
GARMIN_CONSUMER_KEY=''
GARMIN_CONSUMER_SECRET=''
GARMIN_WEBHOOK_SECRET=''

# OpenAI (optional, for AI coach chat)
OPENAI_API_KEY=''

# Vercel deployment (used by `pnpm vercel:pull` / `pnpm vercel:deploy` and
# the manual .github/workflows/vercel-deploy.yml workflow). Get values via
# `vercel link` (writes .vercel/project.json) and https://vercel.com/account/tokens
VERCEL_TOKEN=''
VERCEL_ORG_ID=''
VERCEL_PROJECT_ID=''

# Garmin OAuth 2.0 (Path B — official Garmin Developer Program). Leave blank to
# keep the OAuth flow inert (the addon/garth path is unaffected). Populate after
# Garmin approval issues real credentials + endpoint URLs.
GARMIN_OAUTH_CLIENT_ID=''
GARMIN_OAUTH_CLIENT_SECRET=''
GARMIN_OAUTH_AUTHORIZE_URL=''
GARMIN_OAUTH_TOKEN_URL=''
GARMIN_OAUTH_REDIRECT_URI=''
GARMIN_OAUTH_SCOPES=''

# Official Garmin Health API push webhook (Path B, B4). Off by default; the
# receiver at /api/garmin/oauth/webhook returns 503 until this is 'true'.
GARMIN_HEALTH_WEBHOOK_ENABLED=''
# Optional shared secret matched against the ?token= query param (fail-closed
# only when set). Leave empty to rely on IP allowlisting + user mapping.
GARMIN_HEALTH_WEBHOOK_TOKEN=''
# AES-256-GCM key (base64 of 32 bytes) for encrypting Garmin OAuth tokens at
# rest. Generate: openssl rand -base64 32. Required once GARMIN_OAUTH_* is set.
GARMIN_TOKEN_ENC_KEY=''
